notebooks/*.py
!notebooks/swe_core.py
notebooks/*.nsys-rep
notebooks/*.sqlite
notebooks/*.ncu-rep
notebooks/books__15m.txt
notebooks/test.png

__pycache__/
*.egg-info/
*.log
